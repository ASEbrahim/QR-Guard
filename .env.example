# Database (Neon free tier — get yours at https://neon.tech)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/qrguard?sslmode=require

# Email: 'console' (dev) or 'resend' (production)
EMAIL_PROVIDER=console
RESEND_API_KEY=re_your_key_here

# Session secret (auto-generated on Render, change for local)
SESSION_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
