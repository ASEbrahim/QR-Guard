{
  "name": "qr-guard",
  "version": "0.1.0",
  "description": "Location-based QR attendance system with 6-layer anti-fraud verification",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/backend/server.js",
    "start": "node src/backend/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.{js,html,css}' 'tests/**/*.js'",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
